# CodeRisk Agent - Environment Configuration
# All backends run 100% locally — no cloud API calls.

# LLM Backend: "local_llama_cpp" | "local_http"
LLM_BACKEND=local_llama_cpp

# Local llama-server (HTTP)
LOCAL_HTTP_URL=http://localhost:8080
LOCAL_HTTP_MODEL=qwen2.5-coder-32b-instruct

# Local llama-cpp-python (direct GGUF load)
LOCAL_MODEL_PATH=/workspace/models/qwen2.5-coder-32b-instruct-q4_k_m.gguf
LOCAL_N_GPU_LAYERS=999

# Semgrep
SEMGREP_RULES=p/default

# Local vulnerability databases (built via scripts)
# CODERISK_CVE_DB_PATH=data/vuln_db.sqlite
# CODERISK_OSV_INDEX=data/osv/index.json
